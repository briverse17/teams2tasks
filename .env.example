# OpenAI API key for task inference (required)
OPENAI_API_KEY=your_openai_api_key_here

# User name for task inference (default: Nguyen Minh Vu)
TEAMS_USER_NAME=Nguyen Minh Vu

# Auth file path for Teams login (default: teams_auth.json)
# TEAMS_AUTH_PATH=teams_auth.json

# Output directory for scraped data (default: outputs)
# TEAMS_OUTPUT_DIR=outputs

# Browser settings
# TEAMS_HEADLESS=false
# TEAMS_SLOW_MO=0
# TEAMS_TIMEOUT=60000
# TEAMS_STABILIZE_WAIT=30000
# TEAMS_CLICK_WAIT=10000
